{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": []
        },
        "prisma:generate": {
            "cache": false,
            "outputs": [
                "node_modules/.prisma/**"
            ]
        },
        "prisma:migrate": {
            "cache": false
        },
        "prisma:seed": {
            "cache": false
        }
    }
}